{
  "name": "move_task_from_backlog",
  "description": "Move a task from backlog to a specific day",
  "inputSchema": {
    "type": "object",
    "properties": {
      "taskId": {
        "type": "string",
        "description": "The ID of the task"
      },
      "calendarDay": {
        "type": "string",
        "description": "The target date (YYYY-MM-DD format)"
      }
    },
    "required": ["taskId", "calendarDay"]
  }
}

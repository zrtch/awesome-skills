{
  "name": "move_task_to_day",
  "description": "Reschedule a task to a different day",
  "inputSchema": {
    "type": "object",
    "properties": {
      "taskId": {
        "type": "string",
        "description": "The ID of the task to move"
      },
      "calendarDay": {
        "type": "string",
        "description": "The target date (YYYY-MM-DD format)"
      }
    },
    "required": ["taskId", "calendarDay"]
  }
}
